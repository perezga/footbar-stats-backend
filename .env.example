# Copy to backend/.env (dotenv format — used by docker compose env_file).
# Required:
FOOTBAR_CLIENT_ID=your-client-id
FOOTBAR_CLIENT_SECRET=your-client-secret
COOKIE_SECRET=replace-with-output-of-openssl-rand-hex-32

# Optional — defaults shown. HOST is overridden to 0.0.0.0 in the compose file.
# REDIRECT_URI=https://localhost:4000/auth/callback
# FRONTEND_ORIGIN=http://localhost:5173
# PORT=4000
# HOST=127.0.0.1
